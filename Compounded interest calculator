interest = input("Do you want to compute compounding interest rates? (y/n): ").lower()

def compound_interest():
    principal = 0
    rate = 0
    time = 0
    while True:
        try:
            principal = float(input("Enter the principal: "))
            if principal < 0:
                print("principal can't be less than zero")
            else:
                break
        except ValueError:
            print("Principal must be numerical")

    while True:
        try:
            rate = float(input("Enter the interest rate: "))
            if rate <0:
                print("Interest rate can't be less than zero")
            else:
                break
        except ValueError:
            print("Interest rate must be numerical")
    while True:
        try:
            time = float(input("Enter the time in years: "))
            if time <0:
                print("Time can't be less than zero")
            else:
                break
        except ValueError:
            print("Time must be numerical")
    total = principal * pow((1 + rate / 100), time)
    print(f"your compounded interest after {time} year/s: ${total:.2f}")
    return rerun()

def rerun():
    again = input("would you like to compute more? (y/n): ")
    if again == "y":
        compound_interest()
    elif again == "n":
        exit()
    else:
        print("Please input 'y' or 'n': ")
while True:
    compound_interest()
